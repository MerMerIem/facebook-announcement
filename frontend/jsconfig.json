{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "allowJs": true,
        "checkJs": false,
        "noImplicitAny": false,
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["./src/*"]
        },
        "skipLibCheck": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
